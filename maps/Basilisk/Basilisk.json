    },
    {
      "id": "northern-warding-stone",
      "name": "Northern Warding Stone",
      "point_type": "sanctuary",
      "terrain": "forest",
      "visible": true,
      "description": "A carved stone with protective runes in the Old Forest near the Mud Wallow. One of two Vampire Warding Stones that create an invisible fence vampires cannot cross. The warding line runs southwest to its partner at the river.",
      "x_hint": -0.75,
      "y_hint": -3.03,
      "hex": "0906"
    },
    {
      "id": "southern-warding-stone",
      "name": "Southern Warding Stone",
      "point_type": "sanctuary",
      "terrain": "forest",
      "visible": true,
      "description": "A carved stone with protective runes where the Blackwater River enters the Old Forest. One of two Vampire Warding Stones that create an invisible fence vampires cannot cross. The warding line runs northeast to its partner near the Mud Wallow.",
      "x_hint": -2.25,
      "y_hint": -2.17,
      "hex": "0707"
