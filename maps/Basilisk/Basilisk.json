  "nodes": [
    {
      "id": "blackwater-crossing",
      "name": "Blackwater Crossing",
      "point_type": "heart",
      "terrain": "plains",
      "visible": true,
      "description": "A walled frontier town in Belerion, Dragon Isles, at the intersection of the Old Northern Trade Road and the Blackwater River. Built on both river banks, connected by an old stone bridge. The starting point of the Basilisk Campaign.",
      "x_hint": 0.0,
      "y_hint": 0.0,
      "hex": "1010"
    },
    {
      "id": "laughing-basilisk",
      "name": "The Laughing Basilisk",
      "point_type": "tavern",
      "terrain": "town",
      "visible": true,
      "description": "A tavern inside Blackwater Crossing, near the north gate. The party's home base.",
      "x_hint": 0.0,
      "y_hint": 0.0,
      "hex": "1010",
      "scale": "local",
      "parent": "blackwater-crossing"
    },
    {
      "id": "sweaty-mermaid",
      "name": "The Sweaty Mermaid",
      "point_type": "tavern",
      "terrain": "town",
      "visible": true,
      "description": "A tavern on the east (bad) side of the Blackwater River. Connected to the suspicious meat rumor. Below: stairs to vampire tunnels.",
      "x_hint": 0.0,
      "y_hint": 0.0,
      "hex": "1010",
      "scale": "local",
      "parent": "blackwater-crossing"
    },
    {
      "id": "the-twist",
      "name": "The Twist",
      "point_type": "settlement",
      "terrain": "town",
      "visible": true,
      "description": "A maze of alleys near the Laughing Basilisk. Controlled by a thieves guild (\"canting crew\").",
      "x_hint": 0.0,
      "y_hint": 0.0,
      "hex": "1010",
      "scale": "local",
      "parent": "blackwater-crossing"
    },
    {
      "id": "tunnels-beneath-blackwater",
      "name": "Tunnels Beneath Blackwater Crossing",
      "point_type": "dungeon",
      "terrain": "underground",
      "visible": true,
      "description": "Old tunnels under the city. Contains a vampire brothel. Connected to the mystery of the missing children and the fog.",
      "x_hint": 0.0,
      "y_hint": 0.0,
      "hex": "1010",
      "scale": "local",
      "parent": "blackwater-crossing"
    },
    {
      "id": "abandoned-farmhouse",
      "name": "The Abandoned Farmhouse",
      "point_type": "ruin",
      "terrain": "plains",
      "visible": true,
      "description": "A ruined farmstead along the Trade Road south of BC. Has a basement. There was a fire here.",
      "x_hint": -0.75,
      "y_hint": 0.43,
      "hex": "0910"
    },
    {
      "id": "graveyard",
      "name": "The Graveyard",
      "point_type": "waypoint",
      "terrain": "forest",
      "visible": true,
      "description": "On the Trade Road, 2 hours south of the Old Forest edge. Landmark for navigation to Kalla Cave.",
      "x_hint": 0.0,
      "y_hint": -2.6,
      "hex": "1007"
    },
    {
      "id": "kalla-cave",
      "name": "Kalla Cave",
      "point_type": "dungeon",
      "terrain": "plains",
      "visible": true,
      "description": "4 hours east of the Graveyard. Contains kalla (food). Mud Tooth Porcs relocated here. A stream runs through this hex toward the cave.",
      "x_hint": 1.5,
      "y_hint": -2.6,
      "hex": "1207"
    },
    {
      "id": "mud-wallow",
      "name": "The Mud Wallow",
      "point_type": "sanctuary",
      "terrain": "forest",
      "visible": true,
      "description": "Hot spring west of the Trade Road in the Old Forest. Therapeutic mud heals 1 Heart/hour. Former Mud Tooth Porc territory.",
      "x_hint": -0.75,
      "y_hint": -3.03,
      "hex": "0906"
    },
    {
      "id": "pjork-choppe-hille",
      "name": "Pjörk Choppe Hille",
      "point_type": "settlement",
      "terrain": "forest",
      "visible": true,
      "description": "Organized porc settlement in the Old Forest. ~3/4 day north of BC on the Trade Road, then ~1 hour west.",
      "x_hint": -0.75,
      "y_hint": -3.9,
      "hex": "0905"
    },
    {
      "id": "spider-cave",
      "name": "The Spider Cave",
      "point_type": "dungeon",
      "terrain": "underground",
      "visible": true,
      "description": "Right behind Pjörk Choppe Hille (~1 hour scramble). Daemon spiders, tunnels to skeletal lord's throne room, Evil Chaos Shrine.",
      "x_hint": -0.75,
      "y_hint": -3.9,
      "hex": "0905"
    },
    {
      "id": "crag-cairn",
      "name": "Crag Cairn",
      "point_type": "lair",
      "terrain": "forest",
      "visible": true,
      "description": "SE of Mud Wallow, 2 hours north of Kobold Crevasse. Crag King (barrow wight) on bone throne with 8 skeleton guards. Level 5 encounter.",
      "x_hint": 0.0,
      "y_hint": -4.33,
      "hex": "1005"
    },
    {
      "id": "kobold-crevasse",
      "name": "The Kobold Crevasse",
      "point_type": "settlement",
      "terrain": "forest",
      "visible": true,
      "description": "A deep crevasse in the Old Forest east of the Trade Road. Southern entrance in hex 1005, middle in 1105, northern tip in 1205. A path leads down to a kobold settlement. Mystic ring of trees with thaumaturgical runes at the surface. Home to Yip-Snap and her clan.",
      "x_hint": 0.75,
      "y_hint": -3.9,
      "hex": "1105"
    },
    {
      "id": "fae-glade",
      "name": "The Fae Glade",
      "point_type": "sanctuary",
      "terrain": "forest",
      "visible": true,
      "description": "Old-growth forest between Pjörk Choppe Hille and Thornespire Keep. Silver-bark trees with faces. Time differential: minutes inside = hours outside. Also called \"The Garden.\"",
      "x_hint": -1.5,
      "y_hint": -4.33,
      "hex": "0805"
    },
    {
      "id": "thornespire-keep",
      "name": "Thornespire Keep",
      "point_type": "fortress",
      "terrain": "forest",
      "visible": true,
      "description": "Stone fortress on a hilltop in the Old Forest. ~1.5 days from BC (1 day north to forest, 4 hours west). Outer Bailey, Traveler's Inn, Chapel of Muir. The Castellan governs from the Inner Bailey.",
      "x_hint": -2.25,
      "y_hint": -3.9,
      "hex": "0705"
    },
    {
      "id": "ravens-perch",
      "name": "Raven's Perch",
      "point_type": "ruin",
      "terrain": "forest",
      "visible": true,
      "description": "Abandoned watchtower in the Old Forest, accessed from the Trade Road north of the Thornespire Keep turnoff. Party rescued the Castellan's missing scouts here.",
      "x_hint": -0.75,
      "y_hint": -4.76,
      "hex": "0904"
    },
    {
      "id": "the-swamp",
      "name": "The Swamp",
      "point_type": "wilderness",
      "terrain": "swamp",
      "visible": true,
      "description": "NW of Thornespire Keep, upstream on the Blackwater River. Lizardmen, a hermit who drinks ice wine. Once populated, now flooded.",
      "x_hint": -3.75,
      "y_hint": -4.76,
      "hex": "0504"
    },
    {
      "id": "mistwood-glen",
      "name": "Mistwood Glen",
      "point_type": "sanctuary",
      "terrain": "forest",
      "visible": true,
      "description": "Mystical sanctuary ~2-3 days SW of BC. The Kalla'din pocket realm. Home to the Thornbeard Circle, Snezynja, and Stone-Nose Clan forest trolls.",
      "x_hint": -0.75,
      "y_hint": 2.17,
      "hex": "0912"
    },
    {
      "id": "south-road-mountain-watch",
      "name": "Brunhilde's Mountain Watch Camp",
      "point_type": "waypoint",
      "terrain": "plains",
      "visible": true,
      "description": "Brunhilde Ironfoot's camp & inn on the south road. Waypoint and recruiting camp. Has a moat. Baron Thornwise claims jurisdiction.",
      "x_hint": 0.75,
      "y_hint": 2.17,
      "hex": "1112"
    },
    {
      "id": "serpents-pass",
      "name": "Serpent's Pass",
      "point_type": "waypoint",
      "terrain": "mountains",
      "visible": true,
      "description": "Mountain pass where the Trade Road passes through the Serpent's Teeth Crags. ~2 days south of BC.",
      "x_hint": 0.75,
      "y_hint": 3.03,
      "hex": "1113"
    },
    {
      "id": "bandit-camp",
      "name": "Bandit Ambush Hill",
      "point_type": "lair",
      "terrain": "hills",
      "visible": true,
      "description": "A rocky hill on the western edge of hex 1113, nearest to hex 1013. Covered in stones and natural cover — an excellent position for a small army to camp, like a Weathertop. The bandits from Hangman Hill used this as an ambush site overlooking the main road. Connected to Hangman Hill's water grotto via underground streambed.",
      "x_hint": 0.75,
      "y_hint": 3.03,
      "hex": "1113"
    },
    {
      "id": "tower-of-stargazer",
      "name": "Tower of the Stargazer",
      "point_type": "tower",
      "terrain": "plains",
      "visible": true,
      "description": "Home of Sir Uravulon Calcidius. ~2 days south on Trade Road, half day west. 80-foot stone tower with constant lightning. Calcidius trapped in salt circle ~59 years ago.",
      "x_hint": -0.75,
      "y_hint": 3.03,
      "hex": "0913"
    },
    {
      "id": "vault-of-first-light",
      "name": "Vault of First Light",
      "point_type": "dungeon",
      "terrain": "mountains",
      "visible": true,
      "description": "Ancient dwarven dungeon in the Serpent's Teeth. 2 days south + 1 day overland. Contains traps, the Fallen (undead dwur), cosmic forces.",
      "x_hint": 1.5,
      "y_hint": 4.33,
      "hex": "1215"
    },
    {
      "id": "north-road",
      "name": "The North Road",
